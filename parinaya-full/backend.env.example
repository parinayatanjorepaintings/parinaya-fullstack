# ─── Database ───────────────────────────────────────────────
# Neon DB (development) — copy your connection string from neon.tech
DATABASE_URL=postgresql://username:password@host/dbname?sslmode=require

# Production (VPS PostgreSQL)
# DATABASE_URL=postgresql://parinaya_user:strongpassword@localhost:5432/parinaya_db

# ─── Server ─────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# Your Vercel frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# ─── Auth ────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret_before_production
SESSION_SECRET=another_long_random_secret

# Admin credentials (used only at seed time)
ADMIN_EMAIL=admin@srisriparinaya.com
ADMIN_PASSWORD=Admin@1234

# ─── File Uploads ────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
